

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Resource {
  id           String   @id @default(uuid())
  
  // Cloudinary-dan kelgan to'liq link
  originalUrl  String   @db.Text
  
  // Qisqartirilgan kod (masalan: "x7y2z")
  shortCode    String   @unique 

  ownerId String
  
  // Cloudinary-dan faylni o'chirish uchun kerakli ID
  publicId     String?  
  
  // Analitika: Linkka necha marta bosilgani
  clicks       Int      @default(0)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}